# Database (SQLite for local dev)
DATABASE_URL="file:./prisma/dev.db"

# For Turso (production with Vercel)
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-token"

# HeroSMS API Configuration
HEROSMS_API_KEY="your_herosms_api_key"
HEROSMS_BASE_URL="https://hero-sms.com/stubs/handler_api.php"
HEROSMS_SERVICE="aik"
HEROSMS_COUNTRY="7"

# Admin Authentication
ADMIN_USER="admin"
ADMIN_PASS="changeme"
ADMIN_SECRET="your_jwt_secret_min_32_chars"

# ToyyibPay Payment Integration
TOYYIBPAY_API_KEY="your_toyyibpay_api_key"
TOYYIBPAY_CATEGORY_CODE="your_category_code"
TOYYIBPAY_BASE_URL="https://toyyibpay.com/index.php/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
