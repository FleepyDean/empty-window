generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending_payment
  paid
  active
  shipped
  depleted
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum ClaimStatus {
  waiting_otp
  success
  cancelled
  expired
}

model Order {
  id        Int         @id @default(autoincrement())
  orderId   String      @unique
  // Legacy single-product fields (for backward compatibility)
  productKey String     @default("zus")
  productName String    @default("ZUS Coffee")
  serviceCode String    @default("aik")
  heroServiceCode String @default("aik")
  quantity  Int
  // New multi-product cart support
  items     OrderItem[]
  isCartOrder Boolean   @default(false)
  status    OrderStatus @default(pending_payment)
  source    String      @default("web") // "web" | "shopee" | "admin"
  externalRef String?   @unique // Shopee Order ID for dedup
  totalPrice Decimal    @default(0)
  claims    Claim[]
  payment   Payment?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  productKey      String
  productName     String
  serviceCode     String
  heroServiceCode String
  quantity        Int
  remainingQty    Int      // Quantity left to claim
  pricePerUnit    Decimal  @default(0)
  claims          Claim[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  billCode      String        @unique
  billExternalRef String?
  amount        Decimal       @default(0)
  status        PaymentStatus @default(pending)
  paidAt        DateTime?
  transactionId String?
  metadata      String?       // JSON string for extra data
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProductSetting {
  id         Int      @id @default(autoincrement())
  productKey String   @unique
  priceLabel String
  updatedAt  DateTime @updatedAt
}

model Claim {
  id               Int         @id @default(autoincrement())
  claimId          String      @unique
  orderId          String
  order            Order       @relation(fields: [orderId], references: [orderId], onDelete: Restrict, onUpdate: Cascade)
  orderItemId      Int?        // Links to specific OrderItem for cart orders
  orderItem        OrderItem?  @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  phoneNumber      String
  heroActivationId String      @unique
  status           ClaimStatus @default(waiting_otp)
  otp              String?
  expiresAt        DateTime
  quantityDeducted Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([orderId, status])
  @@index([orderItemId])
}
